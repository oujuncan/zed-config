// Zed settings
// Merged from WangWindow + jellydn/zed-101-setup
{
  "session": {
    "trust_all_worktrees": true
  },
  "base_keymap": "JetBrains",
  "vim_mode": false,
  "cli_default_open_behavior": "existing_window",

  // === 主题 & 外观（保持当前） ===
  "icon_theme": "Material Icon Theme",
  "theme": "Catppuccin Mocha - No Italics",
  "cursor_shape": "bar",
  "cursor_blink": true,

  // === AI Agent ===
  "agent": {
    "use_modifier_to_send": true,
    "model_parameters": [],
    "default_model": {
      "provider": "claude-acp",
      "model": "claude-sonnet-4-6"
    }
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "features": {
    "edit_prediction_provider": "zed"
  },
  "show_edit_predictions": true,

  // === 字体（保持当前） ===
  "ui_font_size": 14,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_fallbacks": ["Sarasa Gothic SC"],
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_fallbacks": ["Sarasa Gothic SC"],
  "buffer_font_features": {
    "calt": true
  },

  // === 编辑器增强（来自 jellydn） ===
  "colorize_brackets": true,
  "code_lens": "on",
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "redact_private_values": true,
  "show_whitespaces": "all",
  "relative_line_numbers": false,
  "unnecessary_code_fade": 0.7,
  "toolbar": {
    "code_actions": true
  },
  "gutter": {
    "line_numbers": true
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "git": {
    "inline_blame": {
      "enabled": true
    }
  },
  "scrollbar": {
    "show": "auto"
  },
  "inlay_hints": {
    "enabled": true
  },

  // === 标签 & 面板 ===
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  "tab_bar": {
    "show": true
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "button": true,
    "dock": "left",
    "default_width": 300,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  "outline_panel": {
    "button": true,
    "dock": "left",
    "default_width": 300
  },
  "git_panel": {
    "tree_view": true,
    "button": true,
    "dock": "left",
    "default_width": 300
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left",
    "default_width": 300
  },
  "debugger": {
    "dock": "right"
  },

  // === 终端 ===
  "terminal": {
    "blinking": "on",
    "cursor_shape": "bar",
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14,
    "line_height": "standard",
    "env": {
      "EDITOR": "zed --wait"
    }
  },

  // === 语言配置 ===
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff", "!basedpyright", "!pyrefly", "!pyright", "!pylsp", "..."],
      "formatter": [
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ],
      "format_on_save": "on",
      "show_edit_predictions": true
    },
    "TypeScript": {
      "show_edit_predictions": true,
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true
      }
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "Markdown": {
      "show_edit_predictions": false,
      "preferred_line_length": 80,
      "format_on_save": "off"
    },
    "JSON": {
      "prettier": {
        "allowed": true,
        "parser": "json"
      }
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": 30,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true
          },
          "closureReturnTypeHints": {
            "enable": "always"
          },
          "diagnostics": {
            "experimental": {
              "enable": true
            }
          },
          "checkOnSave": false,
          "cargo": {
            "allTargets": false
          },
          "check": {
            "workspace": false
          }
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"]
      }
    }
  },

  // === 文件类型 ===
  "file_types": {
    "CMake": ["CMakeLists.txt"],
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },

  // === 文件扫描排除 ===
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/out",
    "**/dist",
    "**/build",
    "**/target",
    "**/.husky",
    "**/.turbo",
    "**/.next",
    "**/.nuxt",
    "**/node_modules",
    "**/__pycache__"
  ],

  // === 行为设置 ===
  "auto_update": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "format_on_save": "on",

  // === 隐私 ===
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  }
}
